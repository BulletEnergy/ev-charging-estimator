# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# local shared-estimate file store (dev fallback when Supabase not configured)
/data

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
*.zip

# stray reference / design-asset folders not part of the app
/Bullet ev estimating/
/Rendering samples/
/CLAUDE-Rendering-Samples-*.md
/CLAUDE-Rendering-Samples-*.txt
/CLAUDE-Start-Rendering-Work.txt
